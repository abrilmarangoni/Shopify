<img src="{{ 'pdp-icon-testtube.svg' | asset_url }}" class="pdp-benefits__preload" style="display:none" alt="" width="24" height="24" loading="lazy">

<style>
  .pdp-benefits {
    --b-bg: #f4f3ee;
    --b-dark: #31331e;
    --b-white: #ffffff;
    --b-radius: .3125rem;
    --f-heading: "Bogart Trial", "Playfair Display", Georgia, serif;
    --f-body: "Figtree", system-ui, sans-serif;
    background-color: var(--b-bg);
    padding: 2.5rem 1rem;
    font-family: var(--f-body);
    color: var(--b-dark);
    overflow: hidden;
  }
  .pdp-benefits-section {
    width: 100vw !important;
    max-width: none !important;
    margin-left: calc(50% - 50vw) !important;
    padding: 0 !important;
    box-sizing: border-box !important;
  }
  .pdp-benefits__container { max-width: 90rem; margin: 0 auto; }
  .pdp-benefits__header { text-align: center; margin-bottom: 1.5rem; }
  .pdp-benefits__heading {
    font-family: var(--f-heading); font-weight: 400;
    font-size: 1.5rem; line-height: 1.25;
    margin: 0 0 .75rem; color: var(--b-dark);
  }
  .pdp-benefits__subheading {
    font-family: var(--f-body); font-size: 1rem; line-height: 1.25rem;
    margin: 0 auto; max-width: 40rem;
  }
  .pdp-benefits__subheading p { margin: 0; }
  .pdp-benefits__subheading strong { font-weight: 700; }

  .pdp-benefits__layout { display: flex; flex-direction: column; gap: 1.5rem; }
  .pdp-benefits__pills { display: flex; flex-direction: column; gap: .625rem; align-items: flex-start; }
  .pdp-benefits__pill-wrapper { display: flex; flex-direction: column; align-items: flex-start; }

  .pdp-benefits__pill {
    display: flex; align-items: center; gap: .625rem;
    padding: .625rem 1.25rem; border: 1px solid var(--b-dark);
    border-radius: 3.125rem; background: transparent; color: var(--b-dark);
    font-family: var(--f-body); font-size: 1rem; line-height: 1.25rem;
    cursor: pointer; transition: background .25s, color .25s;
    width: auto; text-align: left; white-space: nowrap;
  }
  .pdp-benefits__pill:hover { background: rgba(49,51,30,.08); }
  .pdp-benefits__pill.is-active {
    background: var(--b-dark); color: var(--b-white); font-weight: 700;
  }
  .pdp-benefits__pill-icon { width: 1.5rem; height: 1.5rem; flex-shrink: 0; }
  .pdp-benefits__pill-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(0) saturate(100%);
  }
  .pdp-benefits__pill.is-active .pdp-benefits__pill-icon img {
    filter: brightness(0) invert(1);
  }

  .pdp-benefits__mobile-card {
    display: none; background: var(--b-dark); border-radius: var(--b-radius);
    padding: 1.125rem; margin-top: .625rem; color: var(--b-white);
    animation: pdpBenFade .3s ease;
  }
  .pdp-benefits__pill-wrapper.is-active .pdp-benefits__mobile-card { display: block; }

  @keyframes pdpBenFade {
    from { opacity: 0; transform: translateY(-.5rem); }
    to { opacity: 1; transform: translateY(0); }
  }

  .pdp-benefits__card-title {
    font-family: var(--f-heading); font-weight: 400;
    font-size: 1.375rem; line-height: 1.2;
    margin: 0 0 .625rem; color: var(--b-white);
  }
  .pdp-benefits__card-desc {
    font-family: var(--f-body); font-weight: 700;
    font-size: 1rem; line-height: 1.25rem;
    margin: 0 0 .75rem; color: var(--b-white);
  }
  .pdp-benefits__card-bullets {
    list-style: disc; padding-left: 1.5rem; margin: 0 0 1rem;
    font-family: var(--f-body); font-size: 1rem; line-height: 1.25rem;
    color: var(--b-white);
  }
  .pdp-benefits__card-bullets li { margin-bottom: .25rem; }
  .pdp-benefits__card-cta {
    display: inline-flex; align-items: center; gap: .3125rem;
    flex-direction: column;
    color: var(--b-white); font-family: var(--f-body);
    font-size: 1rem; font-weight: 700;
    text-decoration: underline; text-underline-offset: .1875rem;
    transition: opacity .2s;
  }
  .pdp-benefits__card-cta:hover { opacity: .8; }
  .pdp-benefits__card-cta img { width: 1.5rem; height: 1.5rem; filter: brightness(0) invert(1); flex-shrink: 0; }

  .pdp-benefits__desktop-area { display: none; }
  .pdp-benefits__nav { display: none; }

  /* ---- MOBILE: proportional scaling ---- */
  @media (max-width: 47.9375rem) {
    .pdp-benefits {
      --mu: calc(100vw / 390px);
      padding: calc(40px * var(--mu)) calc(20px * var(--mu));
    }
    .pdp-benefits__header { margin-bottom: calc(20px * var(--mu)); text-align: center; }
    .pdp-benefits__heading {
      font-size: calc(24px * var(--mu)); line-height: normal;
      margin: 0 0 calc(12px * var(--mu)); text-align: center;
    }
    .pdp-benefits__subheading {
      font-size: calc(16px * var(--mu)); line-height: normal;
      max-width: 100%; text-align: center;
    }
    .pdp-benefits__layout { gap: calc(20px * var(--mu)); }
    .pdp-benefits__pills { gap: calc(10px * var(--mu)); }
    .pdp-benefits__pill {
      gap: calc(10px * var(--mu));
      padding: calc(10px * var(--mu)) calc(20px * var(--mu));
      border-radius: calc(50px * var(--mu));
      font-size: calc(16px * var(--mu)); line-height: calc(20px * var(--mu));
    }
    .pdp-benefits__pill-icon { width: calc(24px * var(--mu)); height: calc(24px * var(--mu)); }
    .pdp-benefits__mobile-card {
      border-radius: calc(5px * var(--mu));
      padding: calc(18px * var(--mu)); margin-top: calc(10px * var(--mu));
    }
    .pdp-benefits__card-title { font-size: calc(22px * var(--mu)); margin-bottom: calc(10px * var(--mu)); }
    .pdp-benefits__card-desc { font-size: calc(16px * var(--mu)); line-height: calc(20px * var(--mu)); margin-bottom: calc(12px * var(--mu)); }
    .pdp-benefits__card-bullets { font-size: calc(16px * var(--mu)); line-height: calc(20px * var(--mu)); padding-left: calc(24px * var(--mu)); margin-bottom: calc(16px * var(--mu)); }
    .pdp-benefits__card-bullets li { margin-bottom: calc(4px * var(--mu)); }
    .pdp-benefits__card-cta { font-size: calc(16px * var(--mu)); gap: calc(5px * var(--mu)); }
    .pdp-benefits__card-cta img { width: calc(24px * var(--mu)); height: calc(24px * var(--mu)); }
  }

  @media (min-width: 48rem) {
    .pdp-benefits { --u: calc(100vw / 1440px); padding: 0; }
    .pdp-benefits__container {
      position: relative;
      width: 100vw;
      max-width: none;
      margin: 0;
      height: calc(664px * var(--u));
    }

    .pdp-benefits__header {
      position: absolute;
      top: calc(71.2px * var(--u));
      left: calc(85px * var(--u));
      width: calc(654px * var(--u));
      text-align: left;
      margin: 0;
    }
    .pdp-benefits__heading {
      margin: 0;
      width: calc(641px * var(--u));
      font-size: calc(64px * var(--u));
      line-height: calc(70px * var(--u));
    }
    .pdp-benefits__subheading {
      margin: calc(13px * var(--u)) 0 0 calc(9px * var(--u));
      max-width: none;
      width: calc(645px * var(--u));
      height: calc(73px * var(--u));
      font-size: calc(16px * var(--u));
      line-height: calc(20px * var(--u));
      font-weight: 400;
      letter-spacing: 0;
      color: var(--b-dark);
    }
    .pdp-benefits__subheading p { margin: 0; }
    .pdp-benefits__subheading strong { font-weight: 700; }

    .pdp-benefits__layout { display: block; min-height: calc(664px * var(--u)); }
    .pdp-benefits__left {
      position: absolute;
      top: calc(301.2px * var(--u));
      left: calc(92px * var(--u));
      width: calc(335px * var(--u));
      max-width: none;
    }
    .pdp-benefits__pills {
      height: calc(319px * var(--u));
      display: flex;
      justify-content: space-between;
      gap: 0;
    }
    .pdp-benefits__pill {
      min-height: calc(44px * var(--u));
      padding: calc(10px * var(--u)) calc(20px * var(--u));
      gap: calc(10px * var(--u));
      border-radius: calc(50px * var(--u));
      font-size: calc(16px * var(--u));
      line-height: calc(20px * var(--u));
      width: max-content;
      max-width: 100%;
    }
    /* Figma 0:194: middle three pills stretch full width; others are auto-width */
    .pdp-benefits__pill-wrapper:nth-child(2) .pdp-benefits__pill,
    .pdp-benefits__pill-wrapper:nth-child(3) .pdp-benefits__pill,
    .pdp-benefits__pill-wrapper:nth-child(4) .pdp-benefits__pill {
      width: 100%;
    }
    .pdp-benefits__pill-icon { width: calc(24px * var(--u)); height: calc(24px * var(--u)); }
    .pdp-benefits__pill-wrapper.is-active .pdp-benefits__mobile-card { display: none; }

    .pdp-benefits__right {
      position: absolute;
      inset: 0;
      min-height: calc(664px * var(--u));
    }
    .pdp-benefits__desktop-area { display: block; position: absolute; inset: 0; overflow: visible; }
    .pdp-benefits__bg-image {
      position: absolute;
      left: calc(462px * var(--u));
      top: calc(284.4px * var(--u));
      width: calc(331px * var(--u));
      height: calc(353px * var(--u));
      border-radius: calc(5px * var(--u));
      overflow: hidden;
      z-index: 1;
    }
    .pdp-benefits__bg-image img {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      max-width: none;
      object-fit: cover;
    }
    /* Match Figma crop/position per active category image node */
    .pdp-benefits__bg-image img[data-active-index="0"] {
      left: 0;
      top: -23.44%;
      width: 100%;
      height: 164.07%;
      object-fit: fill;
    }
    .pdp-benefits__bg-image img[data-active-index="1"] {
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .pdp-benefits__bg-image img[data-active-index="2"] {
      left: -80.75%;
      top: 0;
      width: 190.21%;
      height: 100%;
      object-fit: fill;
    }
    .pdp-benefits__bg-image img[data-active-index="3"] {
      left: -36.44%;
      top: 0;
      width: 142.2%;
      height: 100%;
      object-fit: fill;
    }
    .pdp-benefits__bg-image img[data-active-index="4"] {
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .pdp-benefits__bg-image img[data-active-index="5"] {
      left: 0;
      top: -1.73%;
      width: 100%;
      height: 133.19%;
      object-fit: fill;
    }

    .pdp-benefits__desktop-card {
      position: absolute;
      right: calc(67px * var(--u));
      top: calc(81.4px * var(--u));
      width: calc(580px * var(--u));
      height: calc(556px * var(--u));
      background: var(--b-dark);
      border-radius: calc(5px * var(--u));
      padding: 0;
      color: var(--b-white);
      z-index: 2;
      display: block;
      overflow: hidden;
    }
    .pdp-benefits__desktop-content {
      position: absolute;
      left: calc(109px * var(--u));
      top: calc(75.8px * var(--u));
      width: calc(363px * var(--u));
      height: calc(439.2px * var(--u));
      opacity: 1;
      transition: opacity .3s;
    }
    .pdp-benefits__desktop-content[data-active-index="0"] { left: calc(109px * var(--u)); top: calc(66.6px * var(--u)); width: calc(363px * var(--u)); height: calc(394px * var(--u)); }
    .pdp-benefits__desktop-content[data-active-index="1"] { left: calc(109px * var(--u)); top: calc(53.6px * var(--u)); width: calc(363px * var(--u)); height: calc(444px * var(--u)); }
    .pdp-benefits__desktop-content[data-active-index="2"] { left: calc(109px * var(--u)); top: calc(43px * var(--u)); width: calc(363px * var(--u)); height: calc(444px * var(--u)); }
    .pdp-benefits__desktop-content[data-active-index="3"] { left: calc(109px * var(--u)); top: calc(63px * var(--u)); width: calc(363px * var(--u)); height: calc(404px * var(--u)); }
    .pdp-benefits__desktop-content[data-active-index="4"] { left: calc(91px * var(--u)); top: calc(82px * var(--u)); width: calc(399px * var(--u)); height: calc(374px * var(--u)); }
    .pdp-benefits__desktop-content[data-active-index="5"] { left: calc(123px * var(--u)); top: calc(64px * var(--u)); width: calc(334px * var(--u)); height: calc(371px * var(--u)); }
    .pdp-benefits__desktop-content.is-fading { opacity: 0; }
    .pdp-benefits__desktop-panel {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      row-gap: 0;
      gap: calc(var(--panel-gap, 35px) * var(--u));
      align-items: start;
      overflow: visible;
    }
    .pdp-benefits__desktop-card .pdp-benefits__card-title {
      margin: 0;
      font-size: calc(48px * var(--u));
      line-height: calc(50px * var(--u));
      width: calc(var(--title-width, 363px) * var(--u));
      height: calc(var(--title-height, 150px) * var(--u));
    }
    .pdp-benefits__desktop-content[data-active-index="0"] .pdp-benefits__desktop-panel { --panel-gap: 35; --title-width: 363; --title-height: 100; --desc-height: 40; --bullets-width: 278; --bullets-height: 100; }
    .pdp-benefits__desktop-content[data-active-index="1"] .pdp-benefits__desktop-panel { --panel-gap: 35; --title-width: 363; --title-height: 150; --desc-height: 40; --bullets-width: 211; --bullets-height: 100; }
    .pdp-benefits__desktop-content[data-active-index="2"] .pdp-benefits__desktop-panel { --panel-gap: 35; --title-width: 363; --title-height: 150; --desc-height: 40; --bullets-width: 169; --bullets-height: 100; }
    .pdp-benefits__desktop-content[data-active-index="3"] .pdp-benefits__desktop-panel { --panel-gap: 35; --title-width: 363; --title-height: 150; --desc-height: 40; --bullets-width: 303; --bullets-height: 60; }
    .pdp-benefits__desktop-content[data-active-index="4"] .pdp-benefits__desktop-panel { --panel-gap: 35; --title-width: 404; --title-height: 100; --desc-height: 40; --bullets-width: 297; --bullets-height: 80; }
    .pdp-benefits__desktop-content[data-active-index="5"] .pdp-benefits__desktop-panel { --panel-gap: 34; --title-width: 357; --title-height: 100; --desc-height: 20; --bullets-width: 324; --bullets-height: 100; }
    .pdp-benefits__desktop-card .pdp-benefits__card-desc {
      margin: 0;
      width: calc(349px * var(--u));
      font-size: calc(16px * var(--u));
      line-height: calc(20px * var(--u));
      font-weight: 700;
      height: calc(var(--desc-height, 40px) * var(--u));
    }
    .pdp-benefits__desktop-card .pdp-benefits__card-bullets {
      margin: 0;
      padding-left: calc(24px * var(--u));
      font-size: calc(16px * var(--u));
      line-height: calc(20px * var(--u));
      white-space: nowrap;
      overflow: visible;
      min-height: auto;
      max-height: none;
      width: calc(var(--bullets-width, 278px) * var(--u));
      height: calc(var(--bullets-height, 100px) * var(--u));
      scrollbar-width: none;
    }
    .pdp-benefits__desktop-card .pdp-benefits__card-bullets::-webkit-scrollbar { display: none; }
    .pdp-benefits__desktop-card .pdp-benefits__card-cta {
      width: calc(307px * var(--u));
      height: calc(49px * var(--u));
      gap: calc(5px * var(--u));
      font-size: calc(16px * var(--u));
      line-height: calc(20px * var(--u));
      text-align: center;
      align-self: center;
      justify-content: center;
    }
    .pdp-benefits__desktop-card .pdp-benefits__card-cta img { width: calc(24px * var(--u)); height: calc(24px * var(--u)); }

    .pdp-benefits__nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: absolute;
      left: calc(438px * var(--u));
      top: calc(512.4px * var(--u));
      width: calc(955px * var(--u));
      z-index: 3;
      pointer-events: none;
    }
    .pdp-benefits__nav-btn {
      width: calc(50px * var(--u));
      height: calc(50px * var(--u));
      border-radius: 50%;
      background: var(--b-white);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 calc(10px * var(--u)) rgba(0,0,0,.15);
      transition: box-shadow .2s, transform .15s;
      pointer-events: auto;
    }
    .pdp-benefits__nav-btn:hover { box-shadow: 0 0 calc(12px * var(--u)) rgba(0,0,0,.22); transform: scale(1.03); }
    .pdp-benefits__nav-btn svg {
      width: calc(28px * var(--u));
      height: calc(28px * var(--u));
      fill: none;
      stroke: var(--b-dark);
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
      transform: translateX(calc(-1px * var(--u)));
    }
    .pdp-benefits__nav-btn.is-next svg { transform: translateX(calc(1px * var(--u))); }
  }
</style>

<div class="pdp-benefits__container">
  {% assign default_bg_url = 'pdp-benefits-brain.png' | asset_url %}
  {% if section.settings.background_image != blank %}
    {% assign default_bg_url = section.settings.background_image | image_url: width: 662 %}
  {% endif %}
  {% assign first_block = section.blocks.first %}
  {% assign initial_bg_url = default_bg_url %}
  {% if first_block and first_block.settings.image != blank %}
    {% assign initial_bg_url = first_block.settings.image | asset_url %}
  {% endif %}

  <div class="pdp-benefits__header">
    {% if section.settings.heading != blank %}
      <h2 class="pdp-benefits__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <div class="pdp-benefits__subheading">{{ section.settings.subheading }}</div>
    {% endif %}
  </div>

  <div class="pdp-benefits__layout">
    <div class="pdp-benefits__left">
      <div class="pdp-benefits__pills" role="tablist">
        {% for block in section.blocks %}
          {% assign panel_bg_url = default_bg_url %}
          {% if block.settings.image != blank %}
            {% assign panel_bg_url = block.settings.image | asset_url %}
          {% endif %}
          <div class="pdp-benefits__pill-wrapper{% if forloop.first %} is-active{% endif %}"
            data-benefits-index="{{ forloop.index0 }}"
            data-benefits-image="{{ panel_bg_url }}"
            {{ block.shopify_attributes }}>
            <button class="pdp-benefits__pill{% if forloop.first %} is-active{% endif %}"
              role="tab" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="benefits-panel-{{ forloop.index0 }}"
              data-benefits-pill="{{ forloop.index0 }}">
              {% if block.settings.icon != blank %}
                <span class="pdp-benefits__pill-icon">
                  <img src="{{ block.settings.icon | asset_url }}" alt="" width="24" height="24" loading="lazy">
                </span>
              {% endif %}
              <span>{{ block.settings.title }}</span>
            </button>

            <div class="pdp-benefits__mobile-card" role="tabpanel" id="benefits-panel-mobile-{{ forloop.index0 }}">
              {% if block.settings.title != blank %}
                <h3 class="pdp-benefits__card-title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <p class="pdp-benefits__card-desc">{{ block.settings.description }}</p>
              {% endif %}
              {% if block.settings.bullets != blank %}
                {% assign items = block.settings.bullets | split: '|' %}
                <ul class="pdp-benefits__card-bullets">
                  {% for item in items %}<li>{{ item | strip }}</li>{% endfor %}
                </ul>
              {% endif %}
              {% if section.settings.cta_text != blank %}
                <a href="{{ section.settings.cta_url | default: '#' }}" class="pdp-benefits__card-cta">
                  <img src="{{ 'pdp-icon-testtube.svg' | asset_url }}" alt="" width="24" height="24" loading="lazy">
                  <span>{{ section.settings.cta_text }}</span>
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="pdp-benefits__right">
      <div class="pdp-benefits__desktop-area">
        <div class="pdp-benefits__bg-image">
          <img
            src="{{ initial_bg_url }}"
            loading="lazy"
            alt="Benefits image"
            width="662"
            height="706"
            data-active-index="0"
            data-benefits-bg
          >
        </div>

        <div class="pdp-benefits__desktop-card">
          <div class="pdp-benefits__desktop-content">
            {% for block in section.blocks %}
              <div class="pdp-benefits__desktop-panel{% if forloop.first %} is-active{% endif %}"
                data-benefits-panel="{{ forloop.index0 }}"
                {% unless forloop.first %}style="display:none"{% endunless %}>
                {% if block.settings.title != blank %}
                  <h3 class="pdp-benefits__card-title">{{ block.settings.title }}</h3>
                {% endif %}
                {% if block.settings.description != blank %}
                  <p class="pdp-benefits__card-desc">{{ block.settings.description }}</p>
                {% endif %}
                {% if forloop.index == 4 and section.settings.cta_text != blank %}
                  <a href="{{ section.settings.cta_url | default: '#' }}" class="pdp-benefits__card-cta">
                    <img src="{{ 'pdp-icon-testtube.svg' | asset_url }}" alt="" width="24" height="24" loading="lazy">
                    <span>{{ section.settings.cta_text }}</span>
                  </a>
                {% endif %}
                {% if block.settings.bullets != blank %}
                  {% assign items = block.settings.bullets | split: '|' %}
                  <ul class="pdp-benefits__card-bullets">
                    {% for item in items %}<li>{{ item | strip }}</li>{% endfor %}
                  </ul>
                {% endif %}
                {% unless forloop.index == 4 %}
                  {% if section.settings.cta_text != blank %}
                    <a href="{{ section.settings.cta_url | default: '#' }}" class="pdp-benefits__card-cta">
                      <img src="{{ 'pdp-icon-testtube.svg' | asset_url }}" alt="" width="24" height="24" loading="lazy">
                      <span>{{ section.settings.cta_text }}</span>
                    </a>
                  {% endif %}
                {% endunless %}
              </div>
            {% endfor %}
          </div>

        </div>
        <div class="pdp-benefits__nav">
          <button class="pdp-benefits__nav-btn" data-benefits-prev aria-label="Previous category">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <button class="pdp-benefits__nav-btn is-next" data-benefits-next aria-label="Next category">
            <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"></polyline></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    var section = document.querySelector('.pdp-benefits');
    if (!section) return;
    var pills = section.querySelectorAll('[data-benefits-pill]');
    var wrappers = section.querySelectorAll('.pdp-benefits__pill-wrapper');
    var panels = section.querySelectorAll('[data-benefits-panel]');
    var wrap = section.querySelector('.pdp-benefits__desktop-content');
    var bgImg = section.querySelector('[data-benefits-bg]');
    var prev = section.querySelector('[data-benefits-prev]');
    var next = section.querySelector('[data-benefits-next]');
    var total = pills.length, idx = 0, busy = false, timer = null;

    function go(i) {
      if (i < 0 || i >= total || busy) return;
      busy = true; idx = i;
      if (wrap) wrap.setAttribute('data-active-index', String(i));
      pills.forEach(function(p, n) { var a = n === i; p.classList.toggle('is-active', a); p.setAttribute('aria-selected', a); });
      wrappers.forEach(function(w, n) { w.classList.toggle('is-active', n === i); });
      if (bgImg && wrappers[i]) {
        var nextImage = wrappers[i].getAttribute('data-benefits-image');
        if (nextImage) bgImg.setAttribute('src', nextImage);
        bgImg.setAttribute('data-active-index', String(i));
      }
      if (wrap) {
        wrap.classList.add('is-fading');
        setTimeout(function() {
          panels.forEach(function(p, n) { p.style.display = n === i ? '' : 'none'; p.classList.toggle('is-active', n === i); });
          wrap.classList.remove('is-fading'); busy = false;
        }, 300);
      } else { busy = false; }
    }

    function startTimer() {
      stopTimer();
      if (total <= 1) return;
      timer = setInterval(function() { go((idx + 1) % total); }, 10000);
    }

    function stopTimer() {
      if (!timer) return;
      clearInterval(timer);
      timer = null;
    }

    function interact(nextIdx) {
      go(nextIdx);
      startTimer();
    }

    pills.forEach(function(p) {
      p.addEventListener('click', function() { interact(+this.getAttribute('data-benefits-pill')); });
    });
    if (prev) prev.addEventListener('click', function() { interact((idx - 1 + total) % total); });
    if (next) next.addEventListener('click', function() { interact((idx + 1) % total); });

    document.addEventListener('visibilitychange', function() {
      if (document.hidden) stopTimer();
      else startTimer();
    });

    startTimer();
    if (wrap) wrap.setAttribute('data-active-index', String(idx));
  })();
</script>

{% schema %}
{
  "name": "PDP - Benefits",
  "tag": "section",
  "class": "pdp-benefits",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "One Natural Solution. Whole-Body Benefits." },
    { "type": "richtext", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "cta_text", "label": "CTA Text", "default": "Explore the science behind these benefits" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" },
    { "type": "image_picker", "id": "background_image", "label": "Background Image" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Benefit Category",
      "limit": 10,
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon filename (from assets)" },
        { "type": "text", "id": "image", "label": "Panel image filename (from assets)" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "bullets", "label": "Bullet Points (pipe-separated)" }
      ]
    }
  ],
  "presets": [{ "name": "PDP - Benefits" }]
}
{% endschema %}
